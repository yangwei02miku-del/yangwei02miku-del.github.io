---
import BaseLayout from "../layouts/BaseLayout.astro";
import { teaching } from "../data/profile";
---

<BaseLayout
  title="Teaching"
  description="Teaching information for Wei Yang."
>
  <article class="page" aria-labelledby="teaching-title">
    <p class="eyebrow">Teaching</p>
    <h1 id="teaching-title">Teaching</h1>

    <p>
      This page lists teaching assistant and exercise session information.
    </p>

    <section aria-labelledby="ta-title">
      <h2 id="ta-title">Teaching Assistantships</h2>
      <ul class="section-list">
        {
          teaching.map((item) => (
            <li>
              <h3>
                <a href={item.href}>{item.course}</a>
              </h3>
              <p>
                {item.role}, {item.institution}.
              </p>
              <p class="muted">{item.terms}</p>
            </li>
          ))
        }
      </ul>
    </section>
  </article>
</BaseLayout>
